                  dataType="System.String"
                  description="Comando SQL para ejecutar."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT 
P.[Id_pv],
P.[NumeroPoliza],
P.[FechaEmision],
P.[FechaInicio],
P.[FechaFin],
P.[AseguradoId],
[SumaAsegurada],
P.[PrimaTotal],
P.[Estado],
Ext.[InfoAdicional],
Ext.[Observaciones]
FROM [dbo].[Polizas] P
INNER JOIN [dbo].[Poliza_Ext] Ext
ON P.Id_pv = Ext.Id_pv</property>
